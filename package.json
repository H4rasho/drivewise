{
  "name": "drivewise",
  "private": true,
  "workspaces": ["packages/*", "apps/*"],
  "scripts": {
    "dev:api": "cd apps/api && bun --watch src/index.ts",
    "dev:web": "cd apps/web && bun run dev",
    "build": "bun run --filter './apps/*' build",
    "db:generate": "bun --env-file=.env run --filter @drivewise/api db:generate",
    "db:migrate": "bun --env-file=.env run --filter @drivewise/api db:migrate",
    "db:seed": "bun --env-file=.env run --filter @drivewise/api db:seed",
    "db:studio": "bun --env-file=.env run --filter @drivewise/api db:studio",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:dev": "docker compose -f docker-compose.dev.yml up --build",
    "docker:dev:down": "docker compose -f docker-compose.dev.yml down",
    "typecheck": "bun run --filter '*' typecheck"
  }
}
